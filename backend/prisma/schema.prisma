generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "sqlite"
 url = env("DATABASE_URL")
}

model Atracao {
 id Int @id @default(autoincrement())
 nome String
 descricao String?
 tipo String
 capacidade Int
 alturaMinima Int
 status String @default("ATIVA")

 clientes Cliente[]
}

model Cliente {
 id Int @id @default(autoincrement())
 nome String
 email String @unique
 telefone String?

 atracaoId Int?
 atracao Atracao? @relation(fields:[atracaoId], references:[id])
}
